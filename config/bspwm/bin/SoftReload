#!/bin/sh
# =============================================================
# Author: gh0stzk
# Repo:   https://github.com/gh0stzk/dotfiles
# Date:   02.02.2025 16:50:44
#
# SoftReload - Dynamic reloading of graphical components
# Features:
#   ✔ Reload POLYBAR or EWW depending on the theme you are in.
#   ✔ Reload PICOM, XSETTINGSD, SXHKD, DUNST daemons and its configurations.
#   ✔ Restart the Eww daemon if it is active
#   ✔ Sends a notification that the configuration has been successfully reloaded.
#
# Copyright (C) 2021-2026 gh0stzk <z0mbi3.zk@protonmail.com>
# Licensed under GPL-3.0 license
# =============================================================

CONFIG_DIR="$HOME/.config/bspwm"
RICES_DIR="$CONFIG_DIR/rices"
DUNST_CONFIG="$HOME/.config/dunst/dunstrc"
read -r CURRENT_RICE < "$CONFIG_DIR"/.rice
main_eww="$CONFIG_DIR/eww"
reloaded=""

# Reload bars polybar or eww
if pgrep -x polybar >/dev/null; then
    polybar-msg cmd restart >/dev/null &&
    reloaded="${reloaded}• Polybar\n"
else
    eww_bar_config="$RICES_DIR/$CURRENT_RICE/bar"
    [ -d "$eww_bar_config" ] && eww reload -c "$eww_bar_config" &&
    reloaded="${reloaded}Eww Bar\n"
fi

# Reload Dunst notification daemon
dunstctl reload 2>/dev/null &&
reloaded="${reloaded}• Dunst\n"

# Reload Picom compositor daemon
pkill -USR1 -x picom 2>/dev/null &&
reloaded="${reloaded}• Picom\n"

# Reload xsettingsd (gtk themes) daemon
pkill -1 xsettingsd 2>/dev/null &&
reloaded="${reloaded}• Gtk Colors\n"

# Reload sxhkd hotkey daemon
pkill -USR1 -x sxhkd 2>/dev/null &&
reloaded="${reloaded}• SXHKD\n"

# Reload EWW widgets
if eww ping -c "$main_eww" >/dev/null; then
    eww reload -c "$main_eww" &&
    reloaded="${reloaded}• Eww Widgets\n"
fi

# Send notification
if [ -n "$reloaded" ]; then
    dunstify \
        -i dialog-information \
        "Environment Reloaded!" \
        "$reloaded"
fi
