# Repo:    https://github.com/gh0stzk/dotfiles
# Date:    03.02.2025 14:22:32
#
# Brightness - Universal brightness control
# Features:
#   ✔ Brightness adjustments in 5% increments
#   ✔ Dynamic monitor detection (focused monitor)
#   ✔ OSD notifications with graphical progress bar
#   ✔ Desktop & Laptop compatible (via xrandr)
#
# Dependencies:
#   → xrandr
#   → dunst
#
# Copyright (C) 2021-2025 gh0stzk <z0mbi3.zk@protonmail.com>
# Licensed under GPL-3.0 license
# =============================================================

DIR="$HOME/.config/bspwm/config/assets"
BRIGHTNESS_STEPS=0.05
MIN_BRIGHTNESS=0.05
MAX_BRIGHTNESS=1.0

OUTPUT=$(bspc query -M -m focused --names)

get_brightness() {
    xrandr --current --verbose | grep -m1 -A5 "$OUTPUT" | grep "Brightness" | awk '{print $2}'
}

send_notification() {
    brightness=$(awk "BEGIN { print int($1 * 100) }")
    icon="$DIR/brightness.svg"

    dunstify "Brightness $brightness%" -i "$icon" -r 5555 -h int:value:"$brightness" &
}

adjust_brightness() {
    current="$(get_brightness)"

    case $1 in
        up)
            new=$(awk "BEGIN { v=$current+$BRIGHTNESS_STEPS; print (v>$MAX_BRIGHTNESS?$MAX_BRIGHTNESS:v) }")
            ;;
        down)
            new=$(awk "BEGIN { v=$current-$BRIGHTNESS_STEPS; print (v<$MIN_BRIGHTNESS?$MIN_BRIGHTNESS:v) }")
            ;;
    esac

    xrandr --output "$OUTPUT" --brightness "$new"
    send_notification "$new"
}

case $1 in
    up|down) adjust_brightness "$1" ;;
esac