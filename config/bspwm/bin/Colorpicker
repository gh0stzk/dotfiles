#!/bin/sh

sleep 0.3
color=$(xcolor -S 10 -P 150)
image=/tmp/${color}.webp

if [ "$color" ]; then
	echo $color | tr -d "\n" | xclip -selection clipboard
	magick -size 90x90 xc:"$color" ${image}
	dunstify -h string:x-dunst-stack-tag:picker -i ${image} "Color Picker" "$color copied to clipboard"
fi
exit
